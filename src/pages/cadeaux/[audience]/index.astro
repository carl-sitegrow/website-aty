---
import HomeLayout from '@layouts/HomeLayout.astro';
import SiteHeader from '@components/site/SiteHeader.astro';
import SiteFooter from '@components/site/SiteFooter.astro';
import ProductCard from '@components/product/ProductCard.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import { siteConfig } from '@/config/site';
import { breadcrumbTrails } from '@/lib/breadcrumb';
import { getProductsByTag } from '@/lib/products';
import { homeContent } from '@/data/content';
import { audienceConfig, getAudienceSlugs, type AudienceSlug } from '@/data/audiences';

export function getStaticPaths() {
  return getAudienceSlugs().map((audience) => ({
    params: { audience },
  }));
}

const { audience } = Astro.params;
const slug = audience as AudienceSlug;
const config = audienceConfig[slug];
const products = getProductsByTag(config.tag);
const title = config.title;
---
<HomeLayout
  title={`${title} | ${siteConfig.siteName}`}
  description={`${title} — sélection Boutique Atypique au Québec.`}
>
  <SiteHeader activeHref="/cadeaux/" />
  <Breadcrumb items={breadcrumbTrails.cadeaux(title)} />
  <main>
    <header class="container-content px-5 pb-10 sm:px-10 lg:px-20">
      <h1 class="font-display text-4xl font-semibold text-forest sm:text-5xl">{title}</h1>
      <p class="mt-4 max-w-2xl text-lg text-ink-muted">
        {products.length} idée{products.length > 1 ? 's' : ''} sélectionnée{products.length > 1 ? 's' : ''}. Les liens mènent aux boutiques partenaires.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        {homeContent.audiences.map((a) => (
          <a
            href={a.href}
            class:list={[
              'rounded-full px-4 py-2 text-sm font-medium border',
              a.href.includes(`/${slug}/`)
                ? 'border-amber bg-amber text-white'
                : 'border-line bg-white text-forest hover:border-amber',
            ]}
          >
            {a.label}
          </a>
        ))}
      </div>
    </header>

    <section class="section-pad bg-white">
      <div class="container-content">
        {products.length === 0 ? (
          <p class="text-ink-muted">
            Aucun produit pour ce filtre pour le moment.{' '}
            <a href="/cadeaux/" class="link-arrow">Voir toutes les idées</a>
          </p>
        ) : (
          <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
            {products.map((product) => (
              <ProductCard product={product} />
            ))}
          </div>
        )}
      </div>
    </section>
  </main>
  <SiteFooter />
</HomeLayout>
