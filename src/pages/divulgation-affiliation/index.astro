---
import HomeLayout from '@layouts/HomeLayout.astro';
import SiteHeader from '@components/site/SiteHeader.astro';
import SiteFooter from '@components/site/SiteFooter.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import { siteConfig } from '@/config/site';
import { affiliationContent } from '@/data/content';
import { breadcrumbTrails } from '@/lib/breadcrumb';
---
<HomeLayout title={`${affiliationContent.title} | ${siteConfig.siteName}`} description={affiliationContent.title}>
  <SiteHeader />
  <Breadcrumb items={breadcrumbTrails.affiliation()} />
  <main class="section-pad !pt-4">
    <div class="container-content max-w-3xl">
      <h1 class="font-display text-4xl font-semibold text-forest">{affiliationContent.title}</h1>
      <div class="mt-10 space-y-5 text-lg leading-relaxed text-ink-muted">
        {affiliationContent.body.map((p) => (
          <p>{p}</p>
        ))}
      </div>
    </div>
  </main>
  <SiteFooter />
</HomeLayout>
