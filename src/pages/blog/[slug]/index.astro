---
import HomeLayout from '@layouts/HomeLayout.astro';
import SiteHeader from '@components/site/SiteHeader.astro';
import SiteFooter from '@components/site/SiteFooter.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import BlogCard from '@components/blog/BlogCard.astro';
import JsonLd from '@components/JsonLd.astro';
import { siteConfig } from '@/config/site';
import { breadcrumbTrails } from '@/lib/breadcrumb';
import { getPublishedArticles, getArticleBySlug } from '@/data/articles';
import { getTopProducts } from '@/lib/products';

export function getStaticPaths() {
  return getPublishedArticles().map((article) => ({
    params: { slug: article.slug },
  }));
}

const { slug } = Astro.params;
const article = getArticleBySlug(slug!);
if (!article) {
  return Astro.redirect('/404/');
}

const related = getPublishedArticles()
  .filter((a) => a.slug !== article.slug)
  .slice(0, 3);
const picks = getTopProducts(5);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: article.title,
  datePublished: article.dateISO,
  author: { '@type': 'Person', name: article.author },
  description: article.excerpt,
  inLanguage: 'fr-CA',
};
---
<HomeLayout
  title={`${article.title} | ${siteConfig.siteName}`}
  description={article.excerpt}
  type="article"
>
  <JsonLd schema={schema} />
  <SiteHeader activeHref="/blog/" />
  <Breadcrumb items={breadcrumbTrails.article(article.title)} />
  <main>
    <header class="container-content px-5 pb-10 text-center sm:px-10 lg:px-20">
      <span class="inline-flex rounded-full bg-forest px-3 py-1.5 text-xs font-bold uppercase text-white">
        {article.category}
      </span>
      <h1 class="mx-auto mt-4 max-w-3xl font-display text-4xl font-semibold leading-tight text-forest-deep sm:text-5xl">
        {article.title}
      </h1>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-4 text-sm text-ink-muted">
        <span class="font-semibold text-ink">Par {article.author}</span>
        <span aria-hidden="true">·</span>
        <time datetime={article.dateISO}>{article.date}</time>
        <span aria-hidden="true">·</span>
        <span>{article.readTime} de lecture</span>
      </div>
    </header>

    <div class="container-content mb-12 aspect-[21/9] overflow-hidden rounded-xl bg-cream-soft mx-5 sm:mx-10 lg:mx-20">
      <div class="flex size-full items-center justify-center text-ink-muted" role="img" aria-label={article.imageAlt}>
        Image hero article
      </div>
    </div>

    <article class="container-content grid gap-12 px-5 pb-20 sm:px-10 lg:grid-cols-[1fr_320px] lg:px-20">
      <div class="prose-article space-y-6 text-lg leading-relaxed text-ink">
        {article.body.map((p) => (
          <p>{p}</p>
        ))}

        <section class="mt-12 overflow-hidden rounded-xl border border-line">
          <h2 class="bg-cream-soft px-5 py-4 font-display text-2xl font-semibold text-forest">
            Le Top 5 en un clin d'œil
          </h2>
          <div class="overflow-x-auto">
            <table class="w-full min-w-[640px] text-left text-sm">
              <thead class="border-b border-line text-ink-muted">
                <tr>
                  <th class="px-5 py-3 font-semibold">Produit</th>
                  <th class="px-5 py-3 font-semibold">Prix (CAD)</th>
                  <th class="px-5 py-3 font-semibold">Pour qui</th>
                  <th class="px-5 py-3 font-semibold">Lien</th>
                </tr>
              </thead>
              <tbody>
                {picks.map((p) => (
                  <tr class="border-b border-line last:border-0">
                    <td class="px-5 py-4 font-medium text-ink">{p.title}</td>
                    <td class="px-5 py-4">{p.priceLabel ?? `${p.priceCad} $`}</td>
                    <td class="px-5 py-4 text-ink-muted">{p.audience ?? '—'}</td>
                    <td class="px-5 py-4">
                      <a href={p.externalUrl} class="font-semibold text-amber hover:underline" target="_blank" rel="noopener noreferrer sponsored">
                        Voir
                      </a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      </div>

      <aside class="space-y-6">
        <div class="rounded-xl border border-line bg-white p-6 shadow-card">
          <h2 class="font-display text-xl font-semibold text-forest">Partager</h2>
          <p class="mt-2 text-sm text-ink-muted">Facebook · Instagram · Copier le lien</p>
        </div>
        <div class="rounded-xl border border-line bg-cream-soft p-6">
          <h2 class="font-display text-xl font-semibold text-forest">À retenir</h2>
          <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-ink-muted">
            <li>Fixez un budget clair</li>
            <li>Privilégiez le local</li>
            <li>Osez l'insolite</li>
          </ul>
        </div>
      </aside>
    </article>

    {related.length > 0 && (
      <section class="section-pad border-t border-line bg-white">
        <div class="container-content">
          <h2 class="heading-display text-3xl">À lire aussi</h2>
          <div class="mt-8 grid gap-8 md:grid-cols-3">
            {related.map((a) => (
              <BlogCard article={a} />
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
  <SiteFooter />
</HomeLayout>
