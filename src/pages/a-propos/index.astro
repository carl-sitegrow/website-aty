---
import HomeLayout from '@layouts/HomeLayout.astro';
import SiteHeader from '@components/site/SiteHeader.astro';
import SiteFooter from '@components/site/SiteFooter.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import { siteConfig } from '@/config/site';
import { aboutContent } from '@/data/content';
import { breadcrumbTrails } from '@/lib/breadcrumb';
---
<HomeLayout
  title={`À propos | ${siteConfig.siteName}`}
  description="L'histoire et l'équipe derrière Boutique Atypique — idées cadeaux originales au Québec."
>
  <SiteHeader />
  <Breadcrumb items={breadcrumbTrails.about()} />
  <main>
    <header class="container-content px-5 pb-12 text-center sm:px-10 lg:px-20">
      <h1 class="font-display text-5xl font-semibold text-forest">{aboutContent.title}</h1>
    </header>

    <section class="section-pad !pt-0">
      <div class="container-content grid gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <h2 class="heading-display text-3xl sm:text-4xl">{aboutContent.historyTitle}</h2>
          <div class="mt-8 space-y-5 text-lg leading-relaxed text-ink-muted">
            {aboutContent.history.map((p) => (
              <p>{p}</p>
            ))}
          </div>
        </div>
        <div class="aspect-[4/3] rounded-xl bg-cream-soft" role="img" aria-label="Visuel histoire Boutique Atypique"></div>
      </div>
    </section>

    <section class="section-pad bg-white">
      <div class="container-content">
        <h2 class="heading-display text-3xl sm:text-4xl">{aboutContent.valuesTitle}</h2>
        <div class="mt-10 grid gap-6 md:grid-cols-3">
          {aboutContent.values.map((v) => (
            <article class="rounded-xl border border-line bg-cream p-8 shadow-card">
              <h3 class="font-display text-xl font-semibold text-ink">{v.title}</h3>
              <p class="mt-3 text-ink-muted leading-relaxed">{v.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-pad">
      <div class="container-content">
        <h2 class="heading-display text-3xl sm:text-4xl">{aboutContent.teamTitle}</h2>
        <div class="mt-10 grid gap-8 md:grid-cols-3">
          {aboutContent.team.map((m) => (
            <article class="rounded-xl border border-line bg-white p-8 shadow-card">
              <div class="aspect-[16/10] rounded-lg bg-cream-soft" aria-hidden="true"></div>
              <h3 class="mt-6 font-display text-xl font-semibold">{m.name}</h3>
              <p class="mt-1 text-sm font-semibold text-amber">{m.role}</p>
              <p class="mt-3 text-sm leading-relaxed text-ink-muted">{m.bio}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-pad bg-white">
      <div class="container-content grid gap-10 lg:grid-cols-2 lg:items-center">
        <div class="rounded-xl border border-line bg-cream p-10">
          <h2 class="heading-display text-3xl">{aboutContent.partnersTitle}</h2>
          <p class="mt-4 text-lg text-ink-muted">{aboutContent.partnersText}</p>
          <a href={aboutContent.partnersHref} class="btn-forest mt-8 inline-flex">
            {aboutContent.partnersCta} <span aria-hidden="true">→</span>
          </a>
        </div>
        <div class="aspect-[4/3] rounded-xl bg-cream-soft" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <SiteFooter />
</HomeLayout>
