---
import HomeLayout from '@layouts/HomeLayout.astro';
import SiteHeader from '@components/site/SiteHeader.astro';
import SiteFooter from '@components/site/SiteFooter.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import { siteConfig } from '@/config/site';
import { contactContent } from '@/data/content';
import { breadcrumbTrails } from '@/lib/breadcrumb';

const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID;
const formAction = formspreeId ? `https://formspree.io/f/${formspreeId}` : undefined;
---
<HomeLayout
  title={`Contact | ${siteConfig.siteName}`}
  description="Contactez Boutique Atypique — questions, soumissions de produits et partenariats."
>
  <SiteHeader />
  <Breadcrumb items={breadcrumbTrails.contact()} />
  <main>
    <header class="container-content px-5 pb-10 text-center sm:px-10 lg:px-20">
      <h1 class="font-display text-5xl font-semibold text-forest">{contactContent.title}</h1>
    </header>

    <section class="section-pad !pt-0">
      <div class="container-content grid gap-10 lg:grid-cols-[1.4fr_0.8fr]">
        <div class="rounded-xl border border-line bg-white p-8 shadow-card sm:p-10">
          <h2 class="font-display text-2xl font-semibold text-forest">{contactContent.formTitle}</h2>
          <p class="mt-2 text-ink-muted">{contactContent.formSubtitle}</p>

          {formAction ? (
            <form class="mt-8 flex flex-col gap-5" action={formAction} method="POST">
              <input type="hidden" name="_subject" value={`Message — ${siteConfig.siteName}`} />
              <div>
                <label class="mb-2 block text-sm font-semibold" for="contact-name">{contactContent.fields.name}</label>
                <input id="contact-name" name="name" type="text" required placeholder={contactContent.fields.namePlaceholder} class="w-full rounded-md border border-line px-4 py-3 focus:border-amber focus:outline-none focus:ring-2 focus:ring-amber/30" />
              </div>
              <div>
                <label class="mb-2 block text-sm font-semibold" for="contact-email">{contactContent.fields.email}</label>
                <input id="contact-email" name="email" type="email" required placeholder={contactContent.fields.emailPlaceholder} class="w-full rounded-md border border-line px-4 py-3 focus:border-amber focus:outline-none focus:ring-2 focus:ring-amber/30" />
              </div>
              <div>
                <label class="mb-2 block text-sm font-semibold" for="contact-topic">{contactContent.fields.subject}</label>
                <select id="contact-topic" name="topic" class="w-full rounded-md border border-line bg-white px-4 py-3 focus:border-amber focus:outline-none focus:ring-2 focus:ring-amber/30">
                  <option value="">{contactContent.fields.subjectPlaceholder}</option>
                  {contactContent.subjects.map((s) => (
                    <option value={s.value}>{s.label}</option>
                  ))}
                </select>
              </div>
              <div>
                <label class="mb-2 block text-sm font-semibold" for="contact-message">{contactContent.fields.message}</label>
                <textarea id="contact-message" name="message" rows="5" required placeholder={contactContent.fields.messagePlaceholder} class="w-full resize-y rounded-md border border-line px-4 py-3 focus:border-amber focus:outline-none focus:ring-2 focus:ring-amber/30" />
              </div>
              <button type="submit" class="btn-primary w-fit">{contactContent.fields.submit}</button>
            </form>
          ) : (
            <div class="mt-8 rounded-lg border border-dashed border-line bg-cream-soft p-6 text-ink-muted">
              <p class="font-semibold text-ink">Formulaire bientôt disponible</p>
              <p class="mt-2 text-sm">
                L'adresse courriel et l'endpoint de formulaire seront branchés dès qu'ils seront prêts.
                En attendant, utilisez les informations ci-contre.
              </p>
            </div>
          )}
        </div>

        <div class="flex flex-col gap-5">
          {contactContent.info.map((card) => (
            <article class="rounded-xl border border-line bg-white p-6 shadow-card">
              <h3 class="font-display text-lg font-semibold text-forest">{card.title}</h3>
              <p class="mt-2 font-medium text-ink">{card.primary}</p>
              <p class="mt-1 text-sm text-ink-muted">{card.secondary}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-pad bg-white">
      <div class="container-content">
        <h2 class="heading-display text-3xl sm:text-4xl">{contactContent.faqTitle}</h2>
        <div class="mt-8 divide-y divide-line rounded-xl border border-line bg-cream">
          {contactContent.faq.map((item) => (
            <details class="group px-5 py-5">
              <summary class="cursor-pointer list-none font-semibold text-ink marker:content-none flex items-center justify-between gap-4">
                {item.q}
                <span class="text-amber transition group-open:rotate-45" aria-hidden="true">+</span>
              </summary>
              <p class="mt-3 text-ink-muted leading-relaxed">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-forest px-5 py-20 text-center text-white sm:px-10">
      <h2 class="font-display text-3xl font-semibold sm:text-4xl">{contactContent.bannerTitle}</h2>
      <p class="mx-auto mt-4 max-w-xl text-white/80">{contactContent.bannerText}</p>
      <a href={contactContent.bannerHref} class="btn-primary mt-8 inline-flex">{contactContent.bannerCta}</a>
    </section>
  </main>
  <SiteFooter />
</HomeLayout>
