---
import { siteConfig } from '@/config/site';

interface Props {
  activeHref?: string;
}

const { activeHref } = Astro.props;
const pathname = Astro.url.pathname;

function isActive(href: string) {
  if (activeHref) return activeHref === href;
  if (href === '/') return pathname === '/';
  return pathname === href || pathname.startsWith(href);
}
---
<header class="sticky top-0 z-40 border-b border-line bg-cream/95 backdrop-blur">
  <div class="container-content flex items-center justify-between gap-6 px-5 py-5 sm:px-10 lg:px-20">
    <a href="/" class="flex items-center gap-3 group" aria-label={`${siteConfig.siteName} — Accueil`}>
      <span class="flex size-10 items-center justify-center rounded-lg bg-forest text-cream" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z" />
          <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12" />
        </svg>
      </span>
      <span class="flex flex-col leading-tight">
        <span class="font-display text-xl font-black text-forest group-hover:text-forest-soft transition-colors">
          {siteConfig.siteName}
        </span>
        <span class="text-[10px] font-semibold uppercase tracking-wider text-amber">Québec</span>
      </span>
    </a>

    <nav class="hidden items-center gap-8 lg:flex" aria-label="Principal">
      {siteConfig.nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'text-[15px] font-semibold transition-colors hover:text-amber',
            isActive(item.href) ? 'text-forest' : 'text-ink',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a href={siteConfig.ctaPrimaryHref} class="btn-primary !px-5 !py-3 !text-sm">
        {siteConfig.ctaPrimary}
      </a>
      <button
        type="button"
        class="inline-flex size-10 items-center justify-center rounded-md border border-line lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-nav"
        data-nav-toggle
      >
        <span class="sr-only">Menu</span>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-nav" class="hidden border-t border-line bg-cream px-5 py-4 lg:hidden" data-nav-panel>
    <ul class="flex flex-col gap-3">
      {siteConfig.nav.map((item) => (
        <li>
          <a href={item.href} class="block py-2 text-base font-semibold text-ink hover:text-amber">
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const toggle = document.querySelector('[data-nav-toggle]');
  const panel = document.querySelector('[data-nav-panel]');
  toggle?.addEventListener('click', () => {
    const open = panel?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
