---
import { siteConfig } from '@/config/site';

const year = new Date().getFullYear();
---
<footer class="bg-forest text-cream">
  <div class="container-content section-pad !pb-10">
    <div class="grid gap-12 md:grid-cols-[1.4fr_1fr_1fr]">
      <div class="max-w-sm">
        <div class="flex items-center gap-3">
          <span class="flex size-10 items-center justify-center rounded-lg bg-cream/10" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z" />
              <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12" />
            </svg>
          </span>
          <span class="font-display text-2xl font-bold">{siteConfig.siteName}</span>
        </div>
        <p class="mt-4 text-sm leading-relaxed text-cream/80">{siteConfig.siteTagline}</p>
      </div>

      <div>
        <h2 class="text-xs font-semibold uppercase tracking-wider text-cream/60">Navigation</h2>
        <ul class="mt-4 flex flex-col gap-3">
          {siteConfig.footerNav.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-cream/90 transition-colors hover:text-amber">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h2 class="text-xs font-semibold uppercase tracking-wider text-cream/60">Légal</h2>
        <ul class="mt-4 flex flex-col gap-3">
          {siteConfig.footerLegal.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-cream/90 transition-colors hover:text-amber">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-4 border-t border-cream/15 pt-8 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-xs text-cream/60">
        © {year} {siteConfig.siteName} Québec. Tous droits réservés.
      </p>
      <div class="flex gap-4" aria-label="Réseaux sociaux">
        <span class="text-cream/50" title="Instagram — à venir">IG</span>
        <span class="text-cream/50" title="Facebook — à venir">FB</span>
        <span class="text-cream/50" title="X — à venir">X</span>
      </div>
    </div>
  </div>
</footer>
