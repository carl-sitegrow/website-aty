---
/**
 * Balises SEO réutilisables : canonical + Open Graph + Twitter Card + hreflang.
 */
import { siteConfig } from '@/config/site';
import { OG_IMAGE, absoluteUrl } from '@/lib/seo';

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  imageWidth?: number;
  imageHeight?: number;
  type?: 'website' | 'article';
}

const {
  title,
  description = '',
  image,
  imageAlt,
  imageWidth,
  imageHeight,
  type = 'website',
} = Astro.props;

const site = Astro.site ?? new URL(siteConfig.url);
const pathname = Astro.url.pathname;
const canonical = absoluteUrl(pathname, site);

const usingDefaultImage = !image;
const ogImage = absoluteUrl(image ?? OG_IMAGE.path, site);
const ogImageAlt = imageAlt ?? title;
const ogWidth = usingDefaultImage ? undefined : imageWidth;
const ogHeight = usingDefaultImage ? undefined : imageHeight;

const twitter = siteConfig.twitterHandle;
---
<link rel="canonical" href={canonical} />

<link rel="alternate" hreflang="fr-CA" href={canonical} />
<link rel="alternate" hreflang="x-default" href={canonical} />

<meta property="og:type" content={type} />
<meta property="og:site_name" content={siteConfig.siteName} />
<meta property="og:locale" content="fr_CA" />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={title} />
{description && <meta property="og:description" content={description} />}
<meta property="og:image" content={ogImage} />
<meta property="og:image:alt" content={ogImageAlt} />
{ogWidth && <meta property="og:image:width" content={String(ogWidth)} />}
{ogHeight && <meta property="og:image:height" content={String(ogHeight)} />}

<meta name="twitter:card" content="summary_large_image" />
{twitter && <meta name="twitter:site" content={twitter} />}
{twitter && <meta name="twitter:creator" content={twitter} />}
<meta name="twitter:title" content={title} />
{description && <meta name="twitter:description" content={description} />}
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={ogImageAlt} />
