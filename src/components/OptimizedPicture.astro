---
interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
}

const {
  src,
  alt,
  width,
  height,
  class: className = 'size-full object-cover',
  loading = 'lazy',
  fetchpriority,
} = Astro.props;
---
<picture>
  <source srcset={`${src}.avif`} type="image/avif" />
  <source srcset={`${src}.webp`} type="image/webp" />
  <img
    src={`${src}.webp`}
    alt={alt}
    width={width}
    height={height}
    class={className}
    loading={loading}
    decoding="async"
    fetchpriority={fetchpriority}
  />
</picture>
