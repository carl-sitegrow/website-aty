# Site Configuration
SITE_URL=https://boutiqueatypique.com
SITE_DOMAIN=boutiqueatypique.com

# Contact (set when mailbox is ready)
CONTACT_EMAIL=

# Optional: Neon (schema ready; unused at MVP build until enrichment pipeline)
DATABASE_URL=

# Optional: Formspree contact endpoint
PUBLIC_FORMSPREE_ID=

# Cloudflare Turnstile (anti-spam)
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional: Port for local development
PORT=4325

# Enable HTTPS in dev (requires accepting self-signed cert in browser)
# DEV_HTTPS=true
